{
  "name": "designcn",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "check": "oxlint && oxfmt --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*": [
      "oxlint",
      "oxfmt --write"
    ]
  },
  "engines": {
    "bun": ">=1.2"
  },
  "packageManager": "bun@1.2.19"
}
